</head>
<body>

    <!-- Audio element for typing sound effect -->
    <audio id="type-sound" src="https://assets.mixkit.co/active_storage/sfx/2568/2568-84.wav" preload="auto"></audio>

    <div class="letter-box">
        <!-- Small back button positioned absolute in the top left corner -->
        <button id="back-button" class="btn-back" onclick="goBack()">←</button>

        <!-- Middle Center Top Title -->
        <div class="bot-title">Chris.Bot</div>

        <!-- Main Display Text Element -->
        <h2 id="story-text">Select an option from the menu:</h2>
         
        <!-- Interactive Container (Starts with Main Menu layout) -->
        <div id="button-container" class="menu-group">
            <button onclick="choosePath('talking_page')">Talk to Chris.Bot</button>
            <button onclick="choosePath('game_page')">Game</button>
            <button onclick="choosePath('about_page')">About</button>
        </div>
    </div>

    <script>
        let pathHistory = [];
        let currentPath = 'start';
        let typeInterval; 

        const typeSound = document.getElementById("type-sound");
        typeSound.volume = 0.4; 

        // Typewriter Engine
        function typeText(element, text, callback) {
            element.innerHTML = "";
            let i = 0;
            
            if (typeInterval) clearInterval(typeInterval);

            if (text.includes("<span") || text.includes("<button")) {
                element.innerHTML = text;
                if (callback) callback();
                return;
            }

            function type() {
                if (i < text.length) {
                    element.innerHTML += text.charAt(i);
                    
                    if (text.charAt(i) !== " ") {
                        typeSound.currentTime = 0; 
                        typeSound.play().catch(e => console.log("Audio play blocked."));
                    }
                    
                    i++;
                    setTimeout(type, 25); 
                } else if (callback) {
                    callback();
                }
            }
            type();
        }

        function goBack() {
            if (pathHistory.length > 0) {
                let previousPath = pathHistory.pop();
                choosePath(previousPath, true);
            }
        }

        // Mini-game processors
        function playRPS(playerChoice) {
            const choices = ['Rock', 'Paper', 'Scissors'];
            const botChoice = choices[Math.floor(Math.random() * 3)];
            let outcome = "";

            if (playerChoice === botChoice) {
                outcome = `We both chose ${botChoice}. It's a tie.`;
            } else if (
                (playerChoice === 'Rock' && botChoice === 'Scissors') ||
                (playerChoice === 'Paper' && botChoice === 'Rock') ||
                (playerChoice === 'Scissors' && botChoice === 'Paper')
            ) {
                outcome = `You chose ${playerChoice}, I chose ${botChoice}.\n\nYou won. Lucky you.`;
            } else {
                outcome = `You chose ${playerChoice}, I chose ${botChoice}.\n\nI win. Try harder next time.`;
            }

            const textElement = document.getElementById("story-text");
            const btnContainer = document.getElementById("button-container");
            btnContainer.innerHTML = "";
            
            typeText(textElement, outcome, function() {
                btnContainer.innerHTML = `
                    <button onclick="choosePath('game_rps')">Play Again</button>
                    <button onclick="choosePath('game_page')">Back to Games</button>
                `;
            });
        }

        function playDice(playerGuess) {
            const roll = Math.floor(Math.random() * 6) + 1;
            let resultText = `The dice rolled a [ ${roll} ].\n`;

            if (playerGuess === roll) {
                resultText += "Wow, you actually guessed it right.";
            } else {
                resultText += "Wrong guess. Told you it's pure luck.";
            }

            const textElement = document.getElementById("story-text");
            const btnContainer = document.getElementById("button-container");
            btnContainer.innerHTML = "";

            typeText(textElement, resultText, function() {
                btnContainer.innerHTML = `
                    <button onclick="choosePath('game_dice')">Guess Again</button>
                    <button onclick="choosePath('game_page')">Back to Games</button>
                `;
            });
        }

        function choosePath(choice, isGoingBack = false) {
            const textElement = document.getElementById("story-text");
            const btnContainer = document.getElementById("button-container");
            const backBtnElement = document.getElementById("back-button");

            if (!isGoingBack && currentPath !== 'start') {
                pathHistory.push(currentPath);
            }
            
            currentPath = choice;

            let targetText = "";
            let targetButtons = "";
            let isMainMenu = false;

            switch(choice) {
                // ================= MAIN MENU PAGES =================
                case 'start':
                    isMainMenu = true;
                    targetText = "Select an option from the menu:";
                    targetButtons = `
                        <button onclick="choosePath('talking_page')">Talk to Chris.Bot</button>
                        <button onclick="choosePath('game_page')">Game</button>
                        <button onclick="choosePath('about_page')">About</button>
                    `;
                    break;

                // ================= GAME MENU SELECTION =================
                case 'game_page':
                    targetText = "What do you want to play?";
