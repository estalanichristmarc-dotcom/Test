<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chris.Bot</title>
    <style>
        body {
            background-color: #ffffff; /* Pure White Background */
            color: #ff6680; /* Rose Pink Text */
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .letter-box {
            background-color: #ffffff; /* Pure White Card */
            border: 2px solid #ff6680; /* Rose Pink Border */
            padding: 45px 35px 35px 35px;
            border-radius: 10px;
            text-align: center;
            width: 550px;
            max-width: 90%;
            box-shadow: 0 4px 20px rgba(255, 102, 128, 0.15); /* Soft Rose Shadow */
            box-sizing: border-box;
            position: relative;
        }
        /* Top Center Text */
        .bot-title {
            font-size: 1.4rem;
            font-weight: bold;
            margin-top: 0;
            margin-bottom: 25px;
            letter-spacing: 2px;
        }
        h2 {
            margin-bottom: 30px;
            font-size: 1.1rem;
            line-height: 1.6;
            color: #ff6680; /* Rose Pink Heading */
            white-space: pre-line;
            min-height: 120px; /* Prevents card jumping up and down during lines */
            display: flex;
            align-items: center;
            justify-content: center;
        }
        /* Main Menu Layout */
        .menu-group {
            display: flex;
            flex-direction: column;
            align-items: flex-start; /* Aligns buttons on the left side */
            gap: 15px;
            padding-left: 20px;
            min-height: 150px;
        }
        .btn-group {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            min-height: 45px;
        }
        button {
            background-color: #ffffff; /* Pure White Button */
            color: #ff6680; /* Rose Pink Text */
            border: 1px solid #ff6680; /* Rose Pink Border */
            padding: 12px 20px;
            font-size: 0.9rem;
            cursor: pointer;
            border-radius: 6px;
            font-family: inherit;
            transition: all 0.2s ease;
        }
        button:hover {
            background-color: #ff6680; /* Fills with Rose Pink on hover */
            color: #ffffff; /* Text turns White on hover */
            border-color: #ff6680;
        }
        /* Top-Left Corner Back Button Styles */
        .btn-back {
            position: absolute;
            top: 15px;
            left: 15px;
            padding: 5px 10px;
            font-size: 0.75rem;
            border-radius: 4px;
            border: 1px solid #ff6680;
            background-color: transparent;
            opacity: 0.6;
            display: none;
        }
        .btn-back:hover {
            opacity: 1;
            background-color: #ff6680;
            color: #ffffff;
        }
        .dead {
            color: #ff6680; 
            font-weight: bold;
            display: block;
            margin-top: 10px;
        }
