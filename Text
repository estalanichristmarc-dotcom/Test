            // Control navigation back arrow visibility
            if (pathHistory.length > 0 && currentPath !== 'start') {
                backBtnElement.style.display = "block";
            } else {
                backBtnElement.style.display = "none";
            }

            // Core text layout rendering
            btnContainer.innerHTML = "";
            typeText(textElement, targetText, function() {
                btnContainer.innerHTML = targetButtons;
            });
        }
    </script>
